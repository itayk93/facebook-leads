# Environment Variables for Facebook Leads Scraper

# Required: Capsolver API Key
CAPSOLVER_API_KEY=your_capsolver_api_key_here

# Optional: Custom search query (default is set in script)
# QUERY=site:facebook.com/groups ("looking for" OR "need" OR "מחפש" OR "צריך") ("developer" OR "מפתח" OR "freelancer" OR "פרילנסר")

# Optional: Number of pages to scrape (default: 3)
# PAGES_TO_SCRAPE=3

# Optional: Headless mode (default: true)
# HEADLESS=true
